<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prop OS | نظام إدارة الأملاك</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=Reem+Kufi:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root{--bg:#0c0f14;--bg2:#12161e;--bg3:#1a1f2d;--brd:#252c3d;--gold:#c9a55c;--gold2:#e4c882;--gold3:#f0dba8;--txt:#e8eaed;--muted:#7a8494;--ok:#4eba6f;--err:#d95555;--warn:#e4a832;--info:#5b9bd5}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;background-image:radial-gradient(ellipse at 15% 5%,rgba(201,165,92,.07) 0%,transparent 50%),radial-gradient(ellipse at 85% 95%,rgba(201,165,92,.04) 0%,transparent 50%)}
h1,h2,h3{font-family:'Reem Kufi',sans-serif}
::selection{background:var(--gold);color:#0c0f14}
.auth{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.auth-card{background:var(--bg2);border:1px solid var(--brd);border-radius:22px;padding:36px;width:100%;max-width:460px;position:relative;overflow:hidden}
.auth-card::before{content:'';position:absolute;top:-40%;right:-20%;width:300px;height:300px;background:radial-gradient(circle,rgba(201,165,92,.15),transparent 70%);pointer-events:none}
.auth-logo-box{display:flex;align-items:center;gap:14px;margin-bottom:28px;position:relative}
.auth-logo{width:56px;height:56px;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:14px;display:grid;place-items:center;font-family:'Reem Kufi',sans-serif;font-weight:700;color:#0c0f14;font-size:22px}
.auth-logo-text h2{font-size:24px;letter-spacing:-.5px}.auth-logo-text span{font-size:12px;color:var(--muted)}
.mode-tabs{display:grid;grid-template-columns:1fr 1fr;gap:6px;background:var(--bg3);padding:4px;border-radius:10px;margin-bottom:20px}
.mode-tab{padding:10px;text-align:center;border-radius:8px;cursor:pointer;font-size:13px;color:var(--muted);transition:.2s;font-weight:500}
.mode-tab.on{background:var(--gold);color:#0c0f14}.mode-tab .ti{display:block;font-size:16px;margin-bottom:1px}
.fg{margin-bottom:14px}.fg label{display:block;font-size:12.5px;color:var(--muted);margin-bottom:4px;font-weight:500}
input,select,textarea{width:100%;background:var(--bg3);border:1px solid var(--brd);color:var(--txt);padding:10px 13px;border-radius:9px;font-family:'Tajawal',sans-serif;font-size:13.5px;transition:.2s}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--gold)}
textarea{resize:vertical;min-height:70px}
.btn{padding:10px 20px;border-radius:9px;font-family:'Tajawal',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;border:none;transition:.2s}
.btn-g{background:var(--gold);color:#0c0f14}.btn-g:hover{background:var(--gold2)}
.btn-o{background:transparent;color:var(--txt);border:1px solid var(--brd)}.btn-o:hover{border-color:var(--gold)}
.btn-sm{padding:6px 12px;font-size:11.5px}
.alert-box{padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px;display:none}
.alert-box.err{background:rgba(217,85,85,.1);color:var(--err)}.alert-box.show{display:block}
header{border-bottom:1px solid var(--brd);background:rgba(12,15,20,.88);backdrop-filter:blur(14px);position:sticky;top:0;z-index:100}
.hi{max-width:1320px;margin:0 auto;padding:14px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.hbrand{display:flex;align-items:center;gap:10px}
.hlogo{width:38px;height:38px;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:9px;display:grid;place-items:center;font-family:'Reem Kufi',sans-serif;font-weight:700;color:#0c0f14;font-size:17px}
.hname{font-family:'Reem Kufi',sans-serif;font-size:17px;font-weight:600}.hsub{font-size:10px;color:var(--muted)}
nav ul{display:flex;list-style:none;gap:3px;flex-wrap:wrap}
nav a{padding:7px 12px;color:var(--muted);text-decoration:none;border-radius:7px;font-size:12.5px;font-weight:500;transition:.2s;cursor:pointer;white-space:nowrap}
nav a:hover{color:var(--txt);background:var(--bg2)}nav a.on{color:var(--gold);background:rgba(201,165,92,.1)}
.uchip{display:flex;align-items:center;gap:8px;padding:5px 5px 5px 12px;background:var(--bg3);border:1px solid var(--brd);border-radius:24px;font-size:12.5px}
.uav{width:26px;height:26px;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:50%;display:grid;place-items:center;color:#0c0f14;font-weight:700;font-size:11px}
.ubtn{background:transparent;border:none;color:var(--muted);cursor:pointer;padding:3px 6px;font-size:11px;border-radius:5px}.ubtn:hover{color:var(--err)}
.nav-badge{background:var(--err);color:#fff;padding:1px 6px;border-radius:10px;font-size:9.5px;margin-right:3px}
.ct{max-width:1320px;margin:0 auto;padding:24px}
.pg{display:none}.pg.on{display:block}
.ph h1{font-size:28px;font-weight:600;margin-bottom:5px;letter-spacing:-.5px}.ph p{color:var(--muted);font-size:13.5px}.ph{margin-bottom:24px}
.stitle{font-size:18px;margin-bottom:14px;display:flex;align-items:center;gap:9px}.stitle::before{content:'';width:3px;height:18px;background:var(--gold);border-radius:2px}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px}
.st{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:16px;position:relative;overflow:hidden}
.st::before{content:'';position:absolute;top:0;right:0;width:70px;height:70px;background:radial-gradient(circle,rgba(201,165,92,.08),transparent 70%)}
.st-l{font-size:10.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px}
.st-v{font-family:'Reem Kufi',sans-serif;font-size:26px;font-weight:600}.st-t{font-size:10.5px;color:var(--ok);margin-top:3px}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:32px}
.card{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:20px;cursor:pointer;transition:.25s;position:relative;overflow:hidden}
.card:hover{border-color:var(--gold);transform:translateY(-2px)}
.card-ico{width:42px;height:42px;border-radius:9px;display:grid;place-items:center;margin-bottom:12px;font-size:20px}
.ico-o{background:rgba(78,186,111,.15);color:var(--ok)}.ico-t{background:rgba(228,168,50,.15);color:var(--warn)}.ico-c{background:rgba(201,165,92,.15);color:var(--gold)}
.card h3{font-size:16px;margin-bottom:4px}.card p{color:var(--muted);font-size:12px;margin-bottom:12px;line-height:1.5}
.card-ft{display:flex;justify-content:space-between;align-items:center;padding-top:10px;border-top:1px solid var(--brd);font-size:10.5px;color:var(--muted)}
.badge{background:rgba(201,165,92,.12);color:var(--gold);padding:2px 8px;border-radius:16px;font-size:10px;font-weight:500}
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);z-index:200;align-items:flex-start;justify-content:center;padding:24px 14px;overflow-y:auto}
.ov.show{display:flex}
.md{background:var(--bg2);border:1px solid var(--brd);border-radius:16px;max-width:700px;width:100%;padding:26px;margin:auto}
.md-h{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--brd)}
.md-h h2{font-size:19px;margin-bottom:3px}.md-h p{color:var(--muted);font-size:12px}
.xbtn{background:transparent;border:1px solid var(--brd);color:var(--muted);width:32px;height:32px;border-radius:7px;cursor:pointer;font-size:15px}.xbtn:hover{color:var(--txt);border-color:var(--gold)}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}.fg2 .full{grid-column:1/-1}
.fa{display:flex;gap:9px;margin-top:20px;padding-top:16px;border-top:1px solid var(--brd);flex-wrap:wrap}
.tbl-box{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;overflow:hidden;margin-bottom:20px}
.tbl-hd{padding:14px 18px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--brd);flex-wrap:wrap;gap:10px}
.tbl-hd h3{font-size:14px}.filters{display:flex;gap:5px;flex-wrap:wrap}
.fchip{padding:4px 10px;background:var(--bg2);border:1px solid var(--brd);border-radius:16px;font-size:11.5px;cursor:pointer;color:var(--muted);transition:.2s}
.fchip.on{background:var(--gold);color:#0c0f14;border-color:var(--gold)}
.tw{overflow-x:auto}table{width:100%;border-collapse:collapse;min-width:600px}
th,td{padding:11px 18px;text-align:right;font-size:12.5px}
th{background:var(--bg2);color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.4px;font-size:10.5px}
tr{border-bottom:1px solid var(--brd)}tr:last-child{border-bottom:none}tr:hover td{background:rgba(201,165,92,.02)}
.tag{display:inline-block;padding:2px 9px;border-radius:16px;font-size:10.5px;font-weight:500}
.tag-o{background:rgba(78,186,111,.15);color:var(--ok)}.tag-t{background:rgba(228,168,50,.15);color:var(--warn)}.tag-c{background:rgba(201,165,92,.15);color:var(--gold)}
.tag-p{background:rgba(217,85,85,.15);color:var(--err)}.tag-d{background:rgba(78,186,111,.15);color:var(--ok)}.tag-f{background:rgba(228,168,50,.15);color:var(--warn)}.tag-cv{background:rgba(91,155,213,.15);color:var(--info)}
.tag-maint{background:rgba(255,152,0,.15);color:#ff9800}.tag-vacant{background:rgba(217,85,85,.15);color:var(--err)}.tag-rented{background:rgba(78,186,111,.15);color:var(--ok)}
.abtn{background:transparent;border:1px solid var(--brd);color:var(--txt);padding:4px 9px;border-radius:5px;font-size:11px;cursor:pointer;font-family:'Tajawal',sans-serif;margin-left:3px}.abtn:hover{border-color:var(--gold);color:var(--gold)}
.abtn.del:hover{border-color:var(--err);color:var(--err)}
.wa-btn{background:rgba(37,211,102,.15);border-color:rgba(37,211,102,.3);color:#25d366;font-size:10.5px}.wa-btn:hover{background:rgba(37,211,102,.25);border-color:#25d366}
.empty{padding:44px 18px;text-align:center;color:var(--muted)}.empty-i{font-size:36px;margin-bottom:8px;opacity:.4}
.al{background:var(--bg3);border:1px solid var(--brd);border-right:3px solid var(--warn);padding:12px 16px;border-radius:9px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:8px}.al.urg{border-right-color:var(--err)}
.al-t{font-weight:600;font-size:13.5px;margin-bottom:2px}.al-d{font-size:12px;color:var(--muted)}.al-days{font-size:11.5px;font-weight:600}
.rgrid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px}
.rcard{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:20px}.rcard h3{font-size:15px;margin-bottom:14px}
.cw{position:relative;height:240px}
.srow{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--brd);font-size:13px}.srow:last-child{border-bottom:none}
.scard{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:20px;margin-bottom:14px}.scard h3{font-size:15px;margin-bottom:6px}.scard p{font-size:12.5px;color:var(--muted);margin-bottom:12px}
.plist{display:grid;gap:8px}
.pi{background:var(--bg2);padding:10px 14px;border-radius:8px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.pi strong{display:block;font-size:13px;margin-bottom:1px}.pi span{color:var(--muted);font-size:11.5px}
.rbadge{background:rgba(201,165,92,.15);color:var(--gold);padding:2px 9px;border-radius:16px;font-size:10.5px}
.ohero{background:linear-gradient(135deg,rgba(201,165,92,.08),rgba(78,186,111,.04));border:1px solid var(--brd);border-radius:14px;padding:24px;margin-bottom:24px;position:relative;overflow:hidden}
.ohero::before{content:'';position:absolute;top:-30%;left:-10%;width:250px;height:250px;background:radial-gradient(circle,rgba(201,165,92,.12),transparent 70%);pointer-events:none}
.ohero h1{font-size:26px;margin-bottom:4px;position:relative}.ohero p{color:var(--muted);font-size:13px;position:relative}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;margin-bottom:28px}
.pcard{background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:20px;transition:.2s}.pcard:hover{border-color:var(--gold)}
.pcard-h{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.pico{width:40px;height:40px;border-radius:9px;background:rgba(201,165,92,.15);display:grid;place-items:center;font-size:18px}
.pstatus{padding:2px 9px;border-radius:16px;font-size:10.5px;font-weight:500}
.ps-r{background:rgba(78,186,111,.15);color:var(--ok)}.ps-v{background:rgba(217,85,85,.15);color:var(--err)}.ps-m{background:rgba(255,152,0,.15);color:#ff9800}
.pstat{display:flex;justify-content:space-between;padding:7px 0;border-top:1px solid var(--brd);font-size:12.5px}.pstat .l{color:var(--muted)}.pstat .v{font-weight:600}
.fab{position:fixed;bottom:24px;left:24px;width:52px;height:52px;border-radius:50%;background:var(--gold);color:#0c0f14;border:none;font-size:22px;cursor:pointer;box-shadow:0 6px 18px rgba(201,165,92,.3);z-index:50}.fab:hover{background:var(--gold2)}
/* market insight box in owner portal */
.mkt-insight{background:var(--bg2);border:1px solid var(--brd);border-radius:10px;padding:14px;margin-top:14px}
.mkt-insight h4{font-size:13px;margin-bottom:10px;color:var(--gold);display:flex;align-items:center;gap:6px}
.mkt-row{display:flex;justify-content:space-between;padding:6px 0;font-size:12px;border-bottom:1px solid rgba(37,44,61,.5)}.mkt-row:last-child{border:none}
.mkt-row .l{color:var(--muted)}.mkt-row .v{font-weight:600}
.mkt-row .up{color:var(--ok)}.mkt-row .down{color:var(--err)}.mkt-row .eq{color:var(--warn)}
.chart-sm{height:180px;margin-top:10px}
.toast{position:fixed;bottom:24px;right:24px;background:var(--bg2);border:1px solid var(--ok);border-right:4px solid var(--ok);padding:12px 18px;border-radius:9px;font-size:13px;z-index:300;display:none;box-shadow:0 8px 24px rgba(0,0,0,.5)}.toast.show{display:block;animation:tIn .3s ease}
@keyframes tIn{from{transform:translateX(-40px);opacity:0}to{transform:translateX(0);opacity:1}}
@media(max-width:768px){.stats,.cards{grid-template-columns:repeat(2,1fr)}.rgrid{grid-template-columns:1fr}.fg2{grid-template-columns:1fr}nav a{padding:5px 8px;font-size:11px}.ct{padding:18px 14px}.ph h1{font-size:24px}}
@media(max-width:480px){.stats,.cards{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- AUTH -->
<div class="auth" id="authScreen">
<div class="auth-card">
<div class="auth-logo-box"><div class="auth-logo">PO</div><div class="auth-logo-text"><h2>Prop OS</h2><span>نظام إدارة الأملاك الذكي</span></div></div>
<div class="mode-tabs"><div class="mode-tab on" data-lt="partner" onclick="swLT('partner')"><span class="ti">🔐</span>شريك / مدير</div><div class="mode-tab" data-lt="owner" onclick="swLT('owner')"><span class="ti">🏠</span>مالك عقار</div></div>
<div id="partnerAuth"><div class="alert-box" id="pErr"></div>
<div class="fg"><label>اسم المستخدم</label><input id="p-user" placeholder="salman"></div>
<div class="fg"><label>كلمة المرور</label><input type="password" id="p-pass" placeholder="••••"></div>
<button class="btn btn-g" style="width:100%" onclick="partnerLogin()">دخول</button>
<p style="text-align:center;font-size:11px;color:var(--muted);margin-top:16px">سلمان (111) · أبو سعد (222) · عبدالقادر (333)</p></div>
<div id="ownerAuth" style="display:none"><div class="alert-box" id="oErr"></div>
<div class="mode-tabs" style="margin-bottom:16px"><div class="mode-tab on" data-om="acc" onclick="swOM('acc')">حساب</div><div class="mode-tab" data-om="code" onclick="swOM('code')">رمز خاص</div></div>
<div id="oAccMode"><div class="fg"><label>اسم المستخدم</label><input id="o-user"></div><div class="fg"><label>كلمة المرور</label><input type="password" id="o-pass"></div><button class="btn btn-g" style="width:100%" onclick="ownerLogin()">دخول</button></div>
<div id="oCodeMode" style="display:none"><div class="fg"><label>الرمز الخاص</label><input id="o-code" placeholder="OWN-XXXX-XXXX"></div><button class="btn btn-g" style="width:100%" onclick="ownerCodeLogin()">دخول بالرمز</button></div>
<p style="text-align:center;font-size:11px;color:var(--muted);margin-top:14px">تواصل مع الشركة لتفعيل حسابك</p></div>
</div></div>

<!-- MAIN APP -->
<div id="mainApp" style="display:none">
<header><div class="hi">
<div class="hbrand"><div class="hlogo">PO</div><div><div class="hname">Prop OS</div><div class="hsub">نظام إدارة الأملاك</div></div></div>
<nav><ul>
<li><a class="on" data-pg="dash" onclick="go('dash')">لوحة التحكم</a></li>
<li><a data-pg="records" onclick="go('records')">السجلات</a></li>
<li><a data-pg="owners" onclick="go('owners')">بوابة الملاك</a></li>
<li><a data-pg="mkt" onclick="go('mkt')">التسويق <span class="nav-badge" id="mktBadge" style="display:none">0</span></a></li>
<li><a data-pg="market" onclick="go('market')">بيانات السوق</a></li>
<li><a data-pg="alerts" onclick="go('alerts')">التنبيهات <span class="nav-badge" id="alertBadge" style="display:none">0</span></a></li>
<li><a data-pg="reports" onclick="go('reports')">التقارير</a></li>
<li><a data-pg="settings" onclick="go('settings')">الإعدادات</a></li>
</ul></nav>
<div class="uchip"><div class="uav" id="uAv">?</div><span id="uNm">--</span><button class="ubtn" onclick="logout()">خروج</button></div>
</div></header>
<div class="ct">

<!-- DASH -->
<div class="pg on" id="pg-dash">
<div class="ph"><h1>أهلاً بك، <span id="welc">--</span></h1><p>لوحة تحكم Prop OS</p></div>
<div class="stats">
<div class="st"><div class="st-l">الملاك</div><div class="st-v" id="cOwn">0</div><div class="st-t">عقارات مدارة</div></div>
<div class="st"><div class="st-l">المستأجرين</div><div class="st-v" id="cTen">0</div><div class="st-t">عقود نشطة</div></div>
<div class="st"><div class="st-l">الشركاء</div><div class="st-v" id="cCom">0</div><div class="st-t">اتفاقيات</div></div>
<div class="st"><div class="st-l">التسويق</div><div class="st-v" id="cMkt">0</div><div class="st-t" id="cMktP" style="color:var(--err)">0 بانتظار</div></div>
</div>
<h2 class="stitle">القوالب</h2>
<div class="cards">
<div class="card" onclick="openM('owner')"><div class="card-ico ico-o">🏠</div><h3>قالب المالك</h3><p>بيانات المالك وشروط الإدارة</p><div class="card-ft"><span class="badge">12 حقل</span><span>← ابدأ</span></div></div>
<div class="card" onclick="openM('tenant')"><div class="card-ico ico-t">🔑</div><h3>قالب المستأجر</h3><p>عقد إيجار وقيمة الإيجار</p><div class="card-ft"><span class="badge">12 حقل</span><span>← ابدأ</span></div></div>
<div class="card" onclick="openM('company')"><div class="card-ico ico-c">🤝</div><h3>قالب الشركاء</h3><p>الحصص والأدوار والأرباح</p><div class="card-ft"><span class="badge">10 حقل</span><span>← ابدأ</span></div></div>
</div></div>

<!-- RECORDS -->
<div class="pg" id="pg-records">
