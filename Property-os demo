// OWNER PORTAL
function renderOP(){
  const props=D.records.filter(r=>r.type==='owner'&&r.name===CO.name);
  let rented=0,maint=0;props.forEach(p=>{if(p.data.status==='rented')rented++;if(p.data.status==='maintenance')maint++});
  const reqs=D.requests.filter(r=>r.ownerId===CO.id);
  $('opP').textContent=props.length;$('opR').textContent=rented;$('opV').textContent=props.length-rented-maint;$('opQ').textContent=reqs.length;

  const g=$('opGrid');
  if(!props.length){g.innerHTML=`<div class="empty" style="grid-column:1/-1"><div class="empty-i">🏠</div>لا توجد عقارات</div>`;return}

  // Destroy old owner charts
  opCharts.forEach(c=>{if(c)c.destroy()});opCharts=[];

  g.innerHTML=props.map((p,idx)=>{
    const rent=parseFloat(p.data.rent)||0;const com=parseFloat(p.data.commission)||0;const net=rent-(rent*com/100);
    const statusLabel=p.data.status==='rented'?'مؤجر':p.data.status==='maintenance'?'تحت الصيانة':'شاغر';
    const statusClass=p.data.status==='rented'?'ps-r':p.data.status==='maintenance'?'ps-m':'ps-v';
    const t=p.data.status==='rented'?D.records.find(r=>r.type==='tenant'&&r.data.property&&p.data.property&&r.data.property.includes(p.data.property.substring(0,10))):null;

    // بيانات السوق
    const mk=D.marketData.find(m=>m.area===p.data.area&&m.type===p.data.propertyType);
    let mktHtml='';
    if(mk){
      const diff=rent-mk.avgRent;const pct=mk.avgRent?Math.round((diff/mk.avgRent)*100):0;
      const cls=diff>0?'up':diff<0?'down':'eq';const arrow=diff>0?'▲':diff<0?'▼':'=';
      mktHtml=`<div class="mkt-insight"><h4>📊 تحليل السوق — ${mk.area}</h4>
      <div class="mkt-row"><span class="l">إيجارك الشهري</span><span class="v">${rent.toLocaleString()} ر.س</span></div>
      <div class="mkt-row"><span class="l">متوسط الحي</span><span class="v">${mk.avgRent.toLocaleString()} ر.س</span></div>
      <div class="mkt-row"><span class="l">الفرق</span><span class="v ${cls}">${arrow} ${Math.abs(pct)}% ${diff>0?'أعلى':'أقل'}</span></div>
      <div class="mkt-row"><span class="l">مدى الأسعار</span><span class="v">${mk.minRent.toLocaleString()} — ${mk.maxRent.toLocaleString()}</span></div>
      <div class="mkt-row"><span class="l">سرعة التأجير</span><span class="v">${mk.avgDays} يوم</span></div>
      <div class="mkt-row"><span class="l">نسبة الإشغال</span><span class="v">${mk.occupancy}%</span></div>
      ${mk.notes?`<div style="margin-top:8px;font-size:11.5px;color:var(--muted)">💡 ${mk.notes}</div>`:''}
      <div class="chart-sm"><canvas id="opch_${idx}"></canvas></div></div>`;
    }else{
      mktHtml=`<div class="mkt-insight" style="border-color:var(--brd)"><h4 style="color:var(--muted)">📊 لا توجد بيانات سوق لهذا الحي</h4><div style="font-size:12px;color:var(--muted)">سيضيفها فريق الإدارة قريباً</div></div>`;
    }

    return`<div class="pcard"><div class="pcard-h"><div class="pico">🏠</div><span class="pstatus ${statusClass}">${statusLabel}</span></div><h3>${p.data.propertyType||'عقار'}</h3><div style="color:var(--muted);font-size:12px;margin-bottom:12px">${p.data.property||'—'}</div>
    <div class="pstat"><span class="l">الإيجار</span><span class="v">${rent.toLocaleString()} ر.س</span></div>
    <div class="pstat"><span class="l">العمولة</span><span class="v">${com}%</span></div>
    <div class="pstat"><span class="l">صافي</span><span class="v" style="color:var(--ok)">${net.toLocaleString()} ر.س</span></div>
    ${t?`<div class="pstat"><span class="l">المستأجر</span><span class="v">${t.name}</span></div>`:''}
    <div style="display:flex;gap:6px;margin-top:12px;padding-top:12px;border-top:1px solid var(--brd)"><button class="abtn" onclick="pdf('${p.id}')">📄 العقد</button>${t?`<button class="abtn" onclick="pdf('${t.id}')">📄 عقد المستأجر</button>`:''}</div>
    ${mktHtml}</div>`}).join('');

  // Render charts after DOM is ready
  setTimeout(()=>{
    props.forEach((p,idx)=>{
      const mk=D.marketData.find(m=>m.area===p.data.area&&m.type===p.data.propertyType);
      if(!mk)return;
      const canvas=$('opch_'+idx);if(!canvas)return;
      const rent=parseFloat(p.data.rent)||0;
      const ch=new Chart(canvas,{type:'bar',data:{
        labels:['عقارك','متوسط الحي','الأعلى','الأقل'],
        datasets:[{label:'ر.س / شهر',data:[rent,mk.avgRent,mk.maxRent,mk.minRent],backgroundColor:['#c9a55c','#5b9bd5','#4eba6f','#d95555'],borderRadius:4}]
      },options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{color:'#7a8494',font:{size:10}},grid:{color:'#252c3d'}},x:{ticks:{color:'#7a8494',font:{family:'Tajawal',size:10}},grid:{display:false}}}}});
      opCharts.push(ch);
    });
  },100);

  // Requests
  const rl=$('opReqList');
  rl.innerHTML=!reqs.length?`<div class="empty"><div class="empty-i">📋</div>لم تقدم طلبات</div>`:reqs.map(r=>{const sc=r.status==='completed'?'tag-d':r.status==='in-progress'?'tag-f':'tag-p';const st=r.status==='completed'?'منجز':r.status==='in-progress'?'قيد المعالجة':'قيد المراجعة';return`<div class="al ${r.status==='pending'?'urg':''}"><div><div class="al-t">${r.title}</div><div class="al-d">${r.type} · ${new Date(r.ts).toLocaleDateString('ar-SA')}</div>${r.reply?`<div style="margin-top:6px;padding:8px;background:var(--bg3);border-radius:6px;font-size:12px"><strong>رد:</strong> ${r.reply}</div>`:''}</div><span class="tag ${sc}">${st}</span></div>`}).join('');
}

function openNewReq(){const props=D.records.filter(r=>r.type==='owner'&&r.name===CO.name);const sel=$('rq-prop');sel.innerHTML='<option value="">--</option>';props.forEach(p=>sel.innerHTML+=`<option value="${p.data.property}">${p.data.propertyType} — ${p.data.property}</option>`);$('rq-title').value='';$('rq-desc').value='';openM('newReq')}
async function submitReq(){const title=v('rq-title').trim();if(!title){toast('العنوان مطلوب',1);return}D.requests.unshift({id:'rq_'+Date.now(),ownerId:CO.id,ownerName:CO.name,type:v('rq-type'),property:v('rq-prop'),title,description:v('rq-desc'),status:'pending',ts:new Date().toISOString(),reply:''});await save();closeM('newReq');renderOP();toast('✓ تم الإرسال')}

// Admin requests
function renderAdminReq(){const el=$('adminReqList');if(!D.requests.length){el.innerHTML=`<div class="empty"><div class="empty-i">✓</div>لا توجد طلبات</div>`;return}el.innerHTML=D.requests.map(r=>{const sc=r.status==='completed'?'tag-d':r.status==='in-progress'?'tag-f':'tag-p';const st=r.status==='completed'?'منجز':r.status==='in-progress'?'قيد المعالجة':'قيد المراجعة';return`<div class="al ${r.status==='pending'?'urg':''}"><div style="flex:1"><div class="al-t">${r.title} <span style="color:var(--muted);font-size:11px">— ${r.ownerName}</span></div><div class="al-d">${r.type} · ${new Date(r.ts).toLocaleDateString('ar-SA')}</div>${r.reply?`<div style="margin-top:6px;padding:8px;background:var(--bg3);border-radius:6px;font-size:12px">الرد: ${r.reply}</div>`:''}</div><div style="display:flex;flex-direction:column;gap:5px;align-items:flex-end"><span class="tag ${sc}">${st}</span><select onchange="chReqSt('${r.id}',this.value)" style="padding:3px 6px;font-size:10.5px"><option value="pending" ${r.status==='pending'?'selected':''}>مراجعة</option><option value="in-progress" ${r.status==='in-progress'?'selected':''}>معالجة</option><option value="completed" ${r.status==='completed'?'selected':''}>منجز</option></select><button class="abtn" onclick="replyReq('${r.id}')">💬 رد</button></div></div>`}).join('')}
async function chReqSt(id,st){const r=D.requests.find(x=>x.id===id);if(r){r.status=st;await save();renderAdminReq();updBadges();toast('✓')}}
async function replyReq(id){const r=D.requests.find(x=>x.id===id);if(!r)return;const rp=prompt('ردك:',r.reply||'');if(rp!==null){r.reply=rp;await save();renderAdminReq();toast('✓')}}

// ALERTS
function getAlerts(){const now=new Date();return D.records.filter(r=>r.type==='tenant'&&r.endDate).map(r=>{const end=new Date(r.endDate);const days=Math.floor((end-now)/864e5);if(days>60)return null;return{r,days,urg:days<=30}}).filter(Boolean).sort((a,b)=>a.days-b.days)}
function renderAlerts(){const al=getAlerts(),el=$('alertList');if(!al.length){el.innerHTML=`<div class="empty"><div class="empty-i">✓</div>لا توجد تنبيهات</div>`;return}el.innerHTML=al.map(a=>`<div class="al ${a.urg?'urg':''}"><div><div class="al-t">عقد ${a.r.name} ${a.days<0?'منتهي':'ينتهي قريباً'}</div><div class="al-d">${a.r.data.property||'—'}</div></div><div class="al-days" style="color:${a.urg?'var(--err)':'var(--warn)'}">${a.days<0?'منتهي':`${a.days} يوم`}</div></div>`).join('')}

// STATS
function updStats(){$('cOwn').textContent=D.records.filter(r=>r.type==='owner').length;$('cTen').textContent=D.records.filter(r=>r.type==='tenant').length;$('cCom').textContent=D.records.filter(r=>r.type==='company').length;$('cMkt').textContent=D.leads.length;const p=D.leads.filter(l=>l.status==='pending').length;$('cMktP').textContent=p+' بانتظار';$('cMktP').style.color=p?'var(--err)':'var(--ok)'}
function updBadges(){const mp=D.leads.filter(l=>l.status==='pending').length;const mb=$('mktBadge');if(mp){mb.textContent=mp;mb.style.display='inline'}else mb.style.display='none';const al=getAlerts().length;const ab=$('alertBadge');if(al){ab.textContent=al;ab.style.display='inline'}else ab.style.display='none';const rp=D.requests.filter(r=>r.status==='pending').length;const rb=$('maintBadge');if(rb){if(rp){rb.textContent=rp;rb.style.display='inline'}else rb.style.display='none'}}
function updMktStats(){$('mAll').textContent=D.leads.length;$('mPend').textContent=D.leads.filter(l=>l.status==='pending').length;$('mDone').textContent=D.leads.filter(l=>l.status==='contacted').length;$('mFollow').textContent=D.leads.filter(l=>l.status==='following').length}

// CHARTS
function destroyCharts(){Object.values(charts).forEach(c=>{if(c)c.destroy()});charts={}}
function renderCharts(){destroyCharts();const co={responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#e8eaed',font:{family:'Tajawal'}}}}};const ow=D.records.filter(r=>r.type==='owner').length,tn=D.records.filter(r=>r.type==='tenant').length,cm=D.records.filter(r=>r.type==='company').length;charts.c1=new Chart($('ch1'),{type:'doughnut',data:{labels:['ملاك','مستأجرين','شركاء'],datasets:[{data:[ow,tn,cm],backgroundColor:['#4eba6f','#e4a832','#c9a55c'],borderColor:'#1a1f2d',borderWidth:2}]},options:co});const rev=D.records.filter(r=>r.type==='tenant').reduce((s,r)=>s+(parseFloat(r.data.rent)||0),0);const mo=Math.round(rev/12);charts.c2=new Chart($('ch2'),{type:'bar',data:{labels:['يناير','فبراير','مارس','أبريل','مايو','يونيو'],datasets:[{label:'الإيرادات',data:[mo,mo,mo,mo,mo,mo],backgroundColor:'#c9a55c',borderRadius:5}]},options:{...co,scales:{y:{ticks:{color:'#7a8494'},grid:{color:'#252c3d'}},x:{ticks:{color:'#7a8494'},grid:{display:false}}}}});const lp=D.leads.filter(l=>l.status==='pending').length,lc=D.leads.filter(l=>l.status==='contacted').length,lf=D.leads.filter(l=>l.status==='following').length,lcv=D.leads.filter(l=>l.status==='converted').length,lcl=D.leads.filter(l=>l.status==='closed').length;charts.c3=new Chart($('ch3'),{type:'doughnut',data:{labels:['بانتظار','تم','متابعة','عميل','مغلق'],datasets:[{data:[lp,lc,lf,lcv,lcl],backgroundColor:['#d95555','#4eba6f','#e4a832','#5b9bd5','#7a8494'],borderColor:'#1a1f2d',borderWidth:2}]},options:co});const totalCom=D.records.filter(r=>r.type==='owner').reduce((s,r)=>{const rent=parseFloat(r.data.rent)||0;const com=parseFloat(r.data.commission)||0;return s+(rent*12*com/100)},0);const totalInv=D.records.filter(r=>r.type==='company').reduce((s,r)=>s+(parseFloat(r.data.investment)||0),0);$('finSum').innerHTML=`<div class="srow"><span style="color:var(--muted)">إيجارات سنوية</span><span style="font-weight:600">${rev.toLocaleString()} ر.س</span></div><div class="srow"><span style="color:var(--muted)">عمولات سنوية</span><span style="font-weight:600">${Math.round(totalCom).toLocaleString()} ر.س</span></div><div class="srow"><span style="color:var(--muted)">رأس المال</span><span style="font-weight:600">${totalInv.toLocaleString()} ر.س</span></div><div class="srow"><span style="color:var(--muted)">عملاء التسويق</span><span style="font-weight:600">${D.leads.length}</span></div>`}

// PDF
function pdf(id){const r=D.records.find(x=>x.id===id);if(!r)return;const{jsPDF}=window.jspdf;const doc=new jsPDF();const T={owner:'Property Owner Contract',tenant:'Tenant Lease Agreement',company:'Partnership Agreement'};doc.setFontSize(20);doc.setTextColor(201,165,92);doc.text('Prop OS',105,20,{align:'center'});doc.setFontSize(13);doc.setTextColor(50,50,50);doc.text(T[r.type],105,30,{align:'center'});doc.setDrawColor(201,165,92);doc.line(20,35,190,35);doc.setFontSize(10);doc.setTextColor(100,100,100);doc.text(`Date: ${r.date}`,20,45);doc.text(`By: ${r.by}`,20,51);let y=64;doc.setFontSize(10);doc.setTextColor(60,60,60);const L={owner:{name:'Owner',id:'ID',phone:'Phone',email:'Email',property:'Property',area:'Area',propertyType:'Type',deed:'Deed',rent:'Monthly Rent (SAR)',commission:'Commission (%)',startDate:'Start',duration:'Duration',status:'Status',notes:'Notes'},tenant:{name:'Tenant',id:'ID',nationality:'Nationality',phone:'Phone',work:'Employer',property:'Property',rent:'Annual Rent (SAR)',payment:'Payment',deposit:'Deposit',startDate:'Start',endDate:'End',notes:'Notes'},company:{company:'Company',cr:'CR',founded:'Founded',partner:'Partner',share:'Share (%)',investment:'Investment (SAR)',role:'Role',authority:'Authority',profits:'Profits',notes:'Notes'}};for(const[k,val]of Object.entries(r.data)){if(!val)continue;const lines=doc.splitTextToSize(`${L[r.type][k]||k}: ${val}`,170);lines.forEach(l=>{if(y>270){doc.addPage();y=20}doc.text(l,20,y);y+=6})}y+=12;if(y>240){doc.addPage();y=30}doc.setDrawColor(200);doc.line(20,y,90,y);doc.line(120,y,190,y);doc.setFontSize(9);doc.text('First Party',40,y+6);doc.text('Second Party',140,y+6);doc.setFontSize(8);doc.setTextColor(150);doc.text('Generated by Prop OS',105,285,{align:'center'});doc.save(`${r.type}_${r.name}.pdf`);toast('✓ PDF')}

// SETTINGS
function renderTeam(){$('teamList').innerHTML=D.users.map(u=>`<div class="pi"><div><strong>${u.name}</strong><span>@${u.username}</span></div><span class="rbadge">${u.role==='partner'?'شريك':'مدير'}${CU&&u.username===CU.username?' (أنت)':''}</span></div>`).join('')}
function doExport(){const json=JSON.stringify({v:'2.0',at:new Date().toISOString(),by:CU?CU.name:'',data:D},null,2);try{navigator.clipboard.writeText(json);toast('✓ تم النسخ')}catch{$('bkText').value=json;openM('backup')}}
function copyBk(){const ta=$('bkText');ta.select();ta.setSelectionRange(0,99999);try{document.execCommand('copy');toast('✓')}catch{toast('انسخ يدوياً',1)}}
function openImport(){$('impText').value='';openM('import')}
async function doImport(){const txt=v('impText').trim();if(!txt){toast('الصق',1);return}if(!confirm('استبدال كل البيانات؟'))return;try{const bk=JSON.parse(txt);if(!bk.data)throw new Error('غير صالح');D=bk.data;if(!D.users||!D.users.length)D.users=[...DU];['records','ownerAccounts','leads','requests','marketData'].forEach(k=>{if(!D[k])D[k]=[]});await save();renderAll();closeM('import');toast(`✓ تم استيراد ${D.records.length} سجل`)}catch(e){toast('خطأ: '+e.message,1)}}

function toast(msg,err){const t=$('toast');t.textContent=msg;t.style.borderColor=err?'var(--err)':'var(--ok)';t.style.borderRightColor=err?'var(--err)':'var(--ok)';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800)}
function renderAll(){updStats();renderRecTB();renderLdTB();renderAlerts();updMktStats();updBadges()}

(async()=>{await load();$('authScreen').style.display='flex'})();
</script>
</body>
