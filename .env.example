# QLVN OS — Environment Variables
# انسخ هذا الملف إلى .env وعبّئ القيم

# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # للـ MCP Server فقط — لا ترفعه في Git

# ============================================
# Gemini (Nawaf AI)
# ============================================
GEMINI_API_KEY=AIza...

# ============================================
# WhatsApp Cloud API
# ============================================
WHATSAPP_TOKEN=your_token
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_VERIFY_TOKEN=any_random_string

# ============================================
# MCP Server
# ============================================
MCP_TRANSPORT=stdio         # stdio | http
PORT=3000                   # للـ HTTP mode فقط

# ============================================
# Pi Agent (يُضاف في Pi فقط)
# ============================================
PI_UNIT_ID=uuid-of-unit
PI_API_KEY=your-pi-api-key
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=qlvin
MQTT_PASSWORD=your-mqtt-password
CLOUDFLARE_TUNNEL_TOKEN=your-token
