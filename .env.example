# =============================
# qlevl — متغيرات البيئة
# =============================

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
PORT=5000

# واتساب Cloud API (Meta Business)
# اتركهم فارغين وضع dev يكتب في log تلقائياً
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v19.0

# واتساب عبر Twilio (خيار بديل — يُفعَّل تلقائياً إن وُجدت القيم الثلاثة)
# TWILIO_WHATSAPP_FROM: رقم Sandbox الافتراضي لـ Twilio هو 14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=14155238886

# الـ host (لإرسال إشعارات الخروج الصامت)
HOST_PHONE=966500000000

# الأجهزة الذكية — Tuya
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=eu

# قاعدة البيانات
DB_PATH=qlevl.db
