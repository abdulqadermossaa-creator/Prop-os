        "door_device_id": "uuid"
      }
    },
    {
      "key": "presence_detected",
      "label_ar": "اكتشاف وجود",
      "icon": "🚶",
      "config_schema": {
        "presence_device_id": "uuid",
        "delay_seconds": 0
      }
    },
    {
      "key": "presence_lost",
      "label_ar": "انتهاء الوجود",
      "icon": "👻",
      "config_schema": {
        "presence_device_id": "uuid",
        "timeout_minutes": 5
      }
    },
    {
      "key": "guest_checked_in",
      "label_ar": "وصول الضيف",
      "icon": "✈️",
      "config_schema": {}
    },
    {
      "key": "checkout_time_reached",
      "label_ar": "وقت المغادرة",
